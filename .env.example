# ─────────────────────────────────────────────────────────────────────────────
# docker compose 환경변수 템플릿 (루트 .env 로 복사해서 사용)
#
#   다른 PC 사용법:  cp .env.example .env   (그러면 docker compose 가 자동으로 읽음)
#
# 이 파일(.env.example)만 git에 커밋되고, 실제 .env 는 .gitignore 로 제외됨(머신별 오버라이드).
# .env 가 없어도 docker-compose.yml 의 기본값이 적용되므로 그대로 docker compose up 해도 됨.
# ─────────────────────────────────────────────────────────────────────────────

# ── PMS Mart (MongoDB OLAP 사전집계 가속) ──────────────────────────────────────
# true  : ETD/ETA·식별자·거래처·항만·영업 필터 조회를 MongoDB Mart 로 가속(sub-second).
# false : 전 쿼리 OLTP(postgres) — 광범위 조회 시 수 초(느림). mongo 없이도 동작.
# docker-compose.yml 기본값은 true (docker 스택은 mongo 를 항상 동반하므로).
PMS_MART_ENABLED=true

# 라우팅 전략:
#   auto      : Mart 미지원 필터(실적일자=performanceDt·서류일자=documentDt·BMS 운임행/서류
#               필터)만 OLTP 폴백, 나머지는 Mart. (권장)
#   mart-only : 항상 Mart. ⚠ line-level 필터가 무시되어 결과가 부정확해질 수 있어 사용 주의.
PMS_MART_ROUTING=auto

# MongoDB 접속 URI (docker 네트워크 기본값 — 서비스명 mongo)
MONGO_URI=mongodb://mongo:27017/pms_mart

# Mart full rebuild 배치/병렬 (POST /api/pms/mart/rebuild?mode=full 시에만 영향)
PMS_MART_BATCH_SIZE=2000
PMS_MART_PARALLELISM=4
