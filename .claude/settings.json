{
  "permissions": {
    "allow": [
      "Bash(touch .claude/.review_skip)",
      "Bash(cat .claude/.task_queue)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash 'C:/vive-coding/portfolio-legacy-to-next/legacy-to-next/.claude/statusline-command.sh'"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'C:/vive-coding/portfolio-legacy-to-next/legacy-to-next/.claude/hooks/invoke_reviewer.sh'",
            "timeout": 1200
          },
          {
            "type": "command",
            "command": "bash 'C:/vive-coding/portfolio-legacy-to-next/legacy-to-next/.claude/slack_notify.sh' 'Task completed.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'C:/vive-coding/portfolio-legacy-to-next/legacy-to-next/.claude/slack_notify.sh' 'Approval required.'"
          }
        ]
      }
    ]
  }
}