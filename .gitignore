# 전체 프로젝트 루트 gitignore
# 백엔드/프론트엔드 공통
# pipeline test

.idea/
.DS_Store
.vite/
.playwright-mcp/
.env*
!.env.example
*.pem

# AWS 자격증명 보관 폴더 (절대 커밋 금지)
docs/credencial/
.claude/.review_pending
.claude/.review_skip
.claude/.deferred_snooze
.claude/review_log/.reviewer_approved
.claude/review_log/.reject_count
.claude/.task_queue
.claude/worktrees/
.claude/settings.local.json
.claude/slack_notify.sh
.claude/.coder_scope

# 1회성 시드 데이터
schema/seed/

# Windows Bash 크래시 덤프
*.stackdump

# EDMS 첨부 로컬 스토리지 (bare bootRun 기본 경로)
back-end/java-spring/storage/

# Gradle
.gradle/
build/

# IntelliJ IDEA 빌드 출력 (프로젝트 루트 + 백엔드 모듈 루트 한정 — adapter/out 같은 깊은 경로 보호)
/out/
back-end/*/out/

# IntelliJ 모듈 파일 / 런타임 로그 (커밋 대상 아님)
*.iml
*.log
